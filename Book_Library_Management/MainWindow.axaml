<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Book_Library_Management.MainWindow"
        x:CompileBindings="False"
        Title="Управление библиотекой книг"
        Width="1100" Height="680"
        MinWidth="800" MinHeight="500"
        WindowStartupLocation="CenterScreen">

    <DockPanel>

        <!-- ═══ Панель инструментов ══════════════════════════════════════ -->
        <Border DockPanel.Dock="Top" Background="#2D2D2D" Padding="8,6">
            <StackPanel Orientation="Horizontal" Spacing="6">
                <Button Content="＋  Добавить книгу"  Click="OnAddBook"       Padding="14,6"/>
                <Button Content="✎  Редактировать"   Click="OnEditBook"      Padding="14,6"/>
                <Button Content="✕  Удалить"          Click="OnDeleteBook"    Padding="14,6"/>
                <Separator Width="1" Background="#555" Margin="6,2"/>
                <Button Content="Авторы"              Click="OnManageAuthors" Padding="14,6"/>
                <Button Content="Жанры"               Click="OnManageGenres"  Padding="14,6"/>
            </StackPanel>
        </Border>

        <!-- ═══ Панель фильтрации ════════════════════════════════════════ -->
        <Border DockPanel.Dock="Top" Background="#3A3A3A" Padding="10,8">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="🔍 Поиск:" VerticalAlignment="Center" Foreground="White"/>
                <TextBox x:Name="SearchBox"
                         Width="230"
                         Watermark="Введите название книги..."
                         TextChanged="OnSearchChanged"/>

                <TextBlock Text="Автор:" VerticalAlignment="Center" Foreground="White" Margin="10,0,0,0"/>
                <ComboBox x:Name="AuthorFilter" Width="190" SelectionChanged="OnFilterChanged"/>

                <TextBlock Text="Жанр:" VerticalAlignment="Center" Foreground="White" Margin="10,0,0,0"/>
                <ComboBox x:Name="GenreFilter" Width="160" SelectionChanged="OnFilterChanged"/>

                <Button Content="Сбросить" Click="OnResetFilters" Padding="10,4" Margin="6,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- ═══ Статусная строка ════════════════════════════════════════ -->
        <Border DockPanel.Dock="Bottom" Background="#1A1A1A" Padding="12,5">
            <TextBlock x:Name="StatusLabel" Text="Готово" Foreground="#AAAAAA"/>
        </Border>

        <!-- ═══ Таблица книг ════════════════════════════════════════════ -->
        <DataGrid x:Name="BooksGrid"
                  Margin="8"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  GridLinesVisibility="All"
                  CanUserReorderColumns="True"
                  CanUserResizeColumns="True"
                  SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID"         Binding="{Binding Id}"               Width="55"/>
                <DataGridTextColumn Header="Название"   Binding="{Binding Title}"             Width="*"/>
                <DataGridTextColumn Header="Автор"      Binding="{Binding Author.FullName}"   Width="185"/>
                <DataGridTextColumn Header="Год"        Binding="{Binding PublishYear}"       Width="65"/>
                <DataGridTextColumn Header="ISBN"       Binding="{Binding ISBN}"              Width="140"/>
                <DataGridTextColumn Header="Жанр"       Binding="{Binding Genre.Name}"        Width="130"/>
                <DataGridTextColumn Header="В наличии"  Binding="{Binding QuantityInStock}"   Width="90"/>
            </DataGrid.Columns>
        </DataGrid>

    </DockPanel>
</Window>
