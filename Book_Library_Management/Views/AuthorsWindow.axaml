<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Book_Library_Management.Views.AuthorsWindow"
        x:CompileBindings="False"
        Title="Управление авторами"
        Width="820" Height="520"
        WindowStartupLocation="CenterOwner">

    <Grid ColumnDefinitions="*,Auto" Margin="10">

        <!-- ═══ Таблица авторов ═════════════════════════════════════════ -->
        <DockPanel Grid.Column="0" Margin="0,0,10,0">

            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal"
                        Spacing="8" Margin="0,0,0,8">
                <Button Content="＋ Добавить"     Click="OnAdd"    Padding="12,5"/>
                <Button Content="✎ Редактировать" Click="OnEdit"   Padding="12,5"/>
                <Button Content="✕ Удалить"        Click="OnDelete" Padding="12,5"/>
            </StackPanel>

            <DataGrid x:Name="AuthorsGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      GridLinesVisibility="All"
                      SelectionMode="Single"
                      SelectionChanged="OnSelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID"             Binding="{Binding Id}"               Width="50"/>
                    <DataGridTextColumn Header="Имя"            Binding="{Binding FirstName}"         Width="*"/>
                    <DataGridTextColumn Header="Фамилия"        Binding="{Binding LastName}"          Width="*"/>
                    <DataGridTextColumn Header="Дата рождения"  Binding="{Binding BirthDateDisplay}"  Width="130"/>
                    <DataGridTextColumn Header="Страна"         Binding="{Binding Country}"           Width="130"/>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>

        <!-- ═══ Форма редактирования ════════════════════════════════════ -->
        <Border Grid.Column="1" Width="240" Padding="14"
                Background="#3A3A3A" CornerRadius="6">
            <StackPanel Spacing="8">
                <TextBlock Text="Имя:" FontWeight="SemiBold"/>
                <TextBox x:Name="FirstNameBox" Watermark="Имя"/>

                <TextBlock Text="Фамилия:" FontWeight="SemiBold"/>
                <TextBox x:Name="LastNameBox" Watermark="Фамилия"/>

                <TextBlock Text="Дата рождения:" FontWeight="SemiBold"/>
                <DatePicker x:Name="BirthDatePicker"/>

                <TextBlock Text="Страна:" FontWeight="SemiBold"/>
                <TextBox x:Name="CountryBox" Watermark="Страна"/>

                <TextBlock x:Name="FormError"
                           Foreground="OrangeRed"
                           TextWrapping="Wrap"
                           IsVisible="False"
                           Margin="0,4,0,0"/>

                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,10,0,0">
                    <Button Content="Сохранить" Click="OnSave"       Padding="12,5"/>
                    <Button Content="Очистить"  Click="OnClearForm"  Padding="12,5"/>
                </StackPanel>
            </StackPanel>
        </Border>

    </Grid>
</Window>
