<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Book_Library_Management.Views.GenresWindow"
        x:CompileBindings="False"
        Title="Управление жанрами"
        Width="720" Height="480"
        WindowStartupLocation="CenterOwner">

    <Grid ColumnDefinitions="*,Auto" Margin="10">

        <!-- ═══ Таблица жанров ══════════════════════════════════════════ -->
        <DockPanel Grid.Column="0" Margin="0,0,10,0">

            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal"
                        Spacing="8" Margin="0,0,0,8">
                <Button Content="＋ Добавить"     Click="OnAdd"    Padding="12,5"/>
                <Button Content="✎ Редактировать" Click="OnEdit"   Padding="12,5"/>
                <Button Content="✕ Удалить"        Click="OnDelete" Padding="12,5"/>
            </StackPanel>

            <DataGrid x:Name="GenresGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      GridLinesVisibility="All"
                      SelectionMode="Single"
                      SelectionChanged="OnSelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID"          Binding="{Binding Id}"          Width="55"/>
                    <DataGridTextColumn Header="Название"    Binding="{Binding Name}"         Width="*"/>
                    <DataGridTextColumn Header="Описание"    Binding="{Binding Description}"  Width="2*"/>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>

        <!-- ═══ Форма редактирования ════════════════════════════════════ -->
        <Border Grid.Column="1" Width="240" Padding="14"
                Background="#3A3A3A" CornerRadius="6">
            <StackPanel Spacing="8">
                <TextBlock Text="Название жанра:" FontWeight="SemiBold"/>
                <TextBox x:Name="NameBox" Watermark="Название"/>

                <TextBlock Text="Описание:" FontWeight="SemiBold"/>
                <TextBox x:Name="DescriptionBox"
                         Watermark="Краткое описание..."
                         AcceptsReturn="True"
                         Height="100"
                         TextWrapping="Wrap"/>

                <TextBlock x:Name="FormError"
                           Foreground="OrangeRed"
                           TextWrapping="Wrap"
                           IsVisible="False"
                           Margin="0,4,0,0"/>

                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,10,0,0">
                    <Button Content="Сохранить" Click="OnSave"      Padding="12,5"/>
                    <Button Content="Очистить"  Click="OnClearForm" Padding="12,5"/>
                </StackPanel>
            </StackPanel>
        </Border>

    </Grid>
</Window>
