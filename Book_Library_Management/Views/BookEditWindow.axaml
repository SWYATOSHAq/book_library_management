<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Book_Library_Management.Views.BookEditWindow"
        x:CompileBindings="False"
        Title="Книга"
        Width="460" Height="430"
        WindowStartupLocation="CenterOwner"
        CanResize="False">

    <StackPanel Margin="24" Spacing="10">

        <TextBlock Text="Название книги:" FontWeight="SemiBold"/>
        <TextBox x:Name="TitleBox" Watermark="Введите название книги"/>

        <TextBlock Text="Автор:" FontWeight="SemiBold"/>
        <ComboBox x:Name="AuthorCombo" HorizontalAlignment="Stretch"
                  PlaceholderText="— выберите автора —"/>

        <Grid ColumnDefinitions="*,16,*">
            <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock Text="Год публикации:" FontWeight="SemiBold"/>
                <NumericUpDown x:Name="YearBox"
                               Minimum="1000" Maximum="2100"
                               Value="2024" FormatString="0"/>
            </StackPanel>
            <StackPanel Grid.Column="2" Spacing="4">
                <TextBlock Text="Количество в наличии:" FontWeight="SemiBold"/>
                <NumericUpDown x:Name="QuantityBox"
                               Minimum="0" Maximum="9999"
                               Value="1" FormatString="0"/>
            </StackPanel>
        </Grid>

        <TextBlock Text="ISBN:" FontWeight="SemiBold"/>
        <TextBox x:Name="IsbnBox" Watermark="978-..."/>

        <TextBlock Text="Жанр:" FontWeight="SemiBold"/>
        <ComboBox x:Name="GenreCombo" HorizontalAlignment="Stretch"
                  PlaceholderText="— выберите жанр —"/>

        <!-- Строка ошибки -->
        <TextBlock x:Name="ErrorLabel"
                   Foreground="OrangeRed"
                   TextWrapping="Wrap"
                   IsVisible="False"/>

        <!-- Кнопки -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                    Spacing="10" Margin="0,8,0,0">
            <Button Content="Сохранить" Click="OnSave" Padding="18,7"/>
            <Button Content="Отмена"    Click="OnCancel" Padding="18,7"/>
        </StackPanel>

    </StackPanel>
</Window>
